# SQL Server (Protel PMS)
SQL_SERVER=192.168.100.7
SQL_DRIVER=ODBC Driver 18 for SQL Server
# Docker: SQL_TRUSTED=yes (Windows auth) does NOT work in Linux containers.
# Use SQL credentials instead:
SQL_TRUSTED=no
SQL_USER=sa
SQL_PASSWORD=yourpassword

# Hotel
HOTEL_ID=1
HOTEL_NAME=Pomegranate Wellness Spa Hotel
HOTEL_TOTAL_ROOMS=167

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Gmail SMTP
# Use an App Password, not your Gmail password.
# Create at: myaccount.google.com → Security → App passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SENDER_NAME=HBIS Morning Briefing
RECIPIENT_NAME=General Manager

# Web Push (run generate_vapid.py to create these)
# Docker: set path to /app/vapid_private.pem (mounted via docker-compose.yml)
VAPID_PRIVATE_KEY=/app/vapid_private.pem
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:dk@bi-automations.com

# Supabase (for push subscriptions)
SUPABASE_URL=https://tqfupsvymisnskiwtjut.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_HOTEL_ID=
